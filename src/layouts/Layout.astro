---
import { getRegion } from "@lib/data/regions";
import { CartSidebar } from "@modules/layout/components/CartSidebar";
import { Nav } from "@modules/layout/components/Nav";
import "@styles/global.css";
import { ClientRouter } from "astro:transitions";

const { countryCode } = Astro.params;

if (!countryCode) {
  return Astro.redirect("/not-found");
}

const region = await getRegion(countryCode);
const regionId = region?.id || null;
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="dns-prefetch"
      href="//medusa-public-images.s3.eu-west-1.amazonaws.com"
    />
    <link
      rel="preconnect"
      href="https://medusa-public-images.s3.eu-west-1.amazonaws.com"
      crossorigin
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro + Medusa Starter</title>
  </head>
  <body>
    <Nav client:load countryCode={countryCode} regionId={regionId} />
    <slot />
    <CartSidebar client:load countryCode={countryCode} />
  </body>
</html>

<style>
  body {
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
    height: 100%;
    max-width: 1440px;
  }
</style>
