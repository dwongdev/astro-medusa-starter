---
export const prerender = false;

import Layout from "@layouts/Layout.astro";

const { countryCode } = Astro.params;
const storeHref = `/${String(countryCode)}/store`;
---

<Layout title="Order Confirmed" description="Your order has been confirmed." noindex>
  <div class="max-w-2xl mx-auto px-4 py-16 text-center">
    <div class="inline-flex items-center justify-center w-16 h-16 bg-black rounded-full mb-6">
      <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none">
        <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    <h1 class="text-3xl font-bold mb-4">Thank you for your order!</h1>
    <p class="text-gray-600 mb-8">
      Your order has been placed successfully. You will receive a confirmation email shortly.
    </p>
    <a
      href={storeHref}
      class="inline-block bg-black text-white py-3 px-8 rounded-md hover:bg-gray-800 transition-colors"
    >
      Continue shopping
    </a>
  </div>
</Layout>
